# ─── AUTH ─────────────────────────────────────────────────────────────────────
# PIN for admin (full access)
NEXT_PUBLIC_ADMIN_PIN=1234
# PIN for staff/user (Sales + Check-In only)
NEXT_PUBLIC_USER_PIN=0000

# ─── GOOGLE SHEETS ────────────────────────────────────────────────────────────
# Your Google Sheet ID (from the URL)
# URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
# Sheet must be shared as "Anyone with the link can view"
# Columns: First Name | Last Name | Phone | Email | Room Number | Schedule Details
NEXT_PUBLIC_GOOGLE_SHEET_ID=your_sheet_id_here

# ─── EMAILJS ──────────────────────────────────────────────────────────────────
# Sign up free at https://www.emailjs.com
# Template variables: {{to_name}}, {{to_email}}, {{room_number}}, {{schedule}}, {{message}}
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# ─── CONTACT ──────────────────────────────────────────────────────────────────
# WhatsApp number (digits only, with country code, e.g. 14155551234)
NEXT_PUBLIC_WHATSAPP_NUMBER=14155551234
# Or website URL
NEXT_PUBLIC_WEBSITE_URL=https://yourwebsite.com
